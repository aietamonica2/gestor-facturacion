# =============================================
# Gestor de Facturacion Contractual — Variables de entorno
# Copiar este archivo a .env y completar los valores reales
# =============================================

# URL base de la API backend (sin barra final)
# En desarrollo local: http://localhost:3001
# En produccion: https://api.tudominio.com
VITE_API_URL=http://localhost:3001

# Entorno de ejecucion (development | staging | production)
VITE_ENV=development

# Timeout de requests a la API en milisegundos
VITE_API_TIMEOUT=10000

# Habilitar logs de debug en consola (true | false)
VITE_DEBUG=false
