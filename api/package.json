{
  "name": "cbt-api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply cbt-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply cbt-db --remote",
    "db:seed:local": "wrangler d1 execute cbt-db --local --file=./seed.sql",
    "db:seed:remote": "wrangler d1 execute cbt-db --remote --file=./seed.sql"
  },
  "dependencies": {
    "hono": "^4.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240529.0",
    "@hono/zod-validator": "^0.2.2",
    "wrangler": "^3.60.0",
    "typescript": "^5.4.0"
  }
}
